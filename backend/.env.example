# Local default: SQLite file next to this .env, no setup required.
# For production, point this at a Postgres instance instead, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/cartiq
DATABASE_URL=sqlite:///./cartiq.db

# Comma-separated list of origins allowed to call this API from a browser.
# The demo store served locally uses http://localhost:5500 by default.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
